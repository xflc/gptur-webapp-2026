---
import Layout from "../layouts/Layout.astro"
import Header from "../components/Header.astro"
import Footer from "../components/Footer.astro"
import PageBanner from "../components/PageBanner.astro"
import { MessageSquare, Map, Plane, LifeBuoy } from "lucide-react"

const steps = [
  {
    icon: MessageSquare,
    title: "1. Ouvimos o seu sonho",
    body: "Conte-nos onde quer ir, quando, com quem e o que o move — cultura, natureza, história ou simplesmente descanso.",
  },
  {
    icon: Map,
    title: "2. Desenhamos o percurso",
    body: "Preparamos uma proposta à medida, com itinerário, alojamentos e experiências selecionadas, ajustada ao seu ritmo e orçamento.",
  },
  {
    icon: Plane,
    title: "3. Tratamos de tudo",
    body: "Voos, vistos, reservas, transferes e guias locais. Trata-se de viajar sem preocupações, do primeiro ao último dia.",
  },
  {
    icon: LifeBuoy,
    title: "4. Acompanhamos a viagem",
    body: "Estamos disponíveis antes, durante e depois — incluindo o apoio na ativação de seguros, se for necessário.",
  },
]
---

<Layout
  title="Circuitos à Medida | GPTur · Companhia das Viagens"
  description="Viagens desenhadas ao detalhe para si ou para o seu grupo — cultura, natureza, história, beleza e espiritualidade, à medida."
>
  <Header />
  <main>
    <PageBanner
      eyebrow="Viagens à medida"
      title="Circuitos à Medida"
      subtitle="Mais do que visitar um destino, vivê-lo. Desenhamos cada viagem em torno de si — do casal em lua de mel ao grupo de amigos ou à empresa."
      crumb="Circuitos à Medida"
    />

    <section class="bg-white py-16">
      <div class="mx-auto max-w-3xl px-5 lg:px-8">
        <div class="space-y-4 text-[0.98rem] leading-relaxed text-foreground/85">
          <p>
            Evoluímos para um mercado muito específico: a organização de viagens à
            medida de cada cliente, ou grupo de clientes, que proporcionem
            experiências completas — por fora e por dentro.
          </p>
          <p>
            Em cada proposta, a <strong class="text-foreground">cultura</strong>, a
            <strong class="text-foreground">natureza</strong>, a
            <strong class="text-foreground">história</strong>, a
            <strong class="text-foreground">beleza</strong> e a
            <strong class="text-foreground">espiritualidade</strong> fazem de cada
            viagem um ponto de mudança. Sem programas de prateleira: só o que faz
            sentido para si.
          </p>
        </div>
      </div>
    </section>

    <section class="bg-cream py-16">
      <div class="mx-auto max-w-7xl px-5 lg:px-8">
        <h2 class="font-display text-3xl text-ink">Como funciona</h2>
        <div class="mt-10 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
          {
            steps.map((s) => (
              <div class="border-t border-border pt-6">
                <s.icon className="text-primary" size={28} strokeWidth={1.5} />
                <h3 class="mt-4 font-display text-xl text-ink">{s.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{s.body}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="bg-primary py-16 text-primary-foreground">
      <div class="mx-auto flex max-w-4xl flex-col items-center px-5 text-center lg:px-8">
        <h2 class="font-display text-3xl text-white sm:text-4xl">
          Vamos desenhar a sua próxima viagem?
        </h2>
        <p class="mt-3 max-w-xl text-white/80">
          Diga-nos o que tem em mente. Respondemos com uma proposta pensada de raiz.
        </p>
        <div class="mt-7 flex flex-wrap justify-center gap-3">
          <a
            href="mailto:altalisboa@gptur.pt,lisboa@gptur.pt?subject=Pedido de circuito à medida"
            class="flex h-12 items-center rounded-md bg-accent px-7 text-sm font-semibold uppercase tracking-widest text-accent-foreground transition-colors hover:bg-gold-400"
            >Pedir proposta</a
          >
          <a
            href="/contactos"
            class="flex h-12 items-center rounded-md border border-white/40 px-7 text-sm font-semibold uppercase tracking-widest text-white transition-colors hover:bg-white/10"
            >Contactos</a
          >
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
