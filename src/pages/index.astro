---
import Layout from "../layouts/Layout.astro"
import Header from "../components/Header.astro"
import Hero from "../components/Hero.tsx"
import Intro from "../components/Intro.astro"
import FeaturedTrips from "../components/FeaturedTrips.astro"
import Distinguish from "../components/Distinguish.astro"
import Testimonials from "../components/Testimonials.astro"
import Newsletter from "../components/Newsletter.astro"
import DestinationsIndex from "../components/DestinationsIndex.astro"
import Footer from "../components/Footer.astro"
import { offers, offerImage, hasHeroImage, shuffleByDay, offerTitle } from "../data/offers"

// slides do hero: uma oferta por região, escolhida ALEATORIAMENTE entre as que
// têm imagem de qualidade (≥1500px) e descrição própria. A rotação diária é feita
// NO BROWSER pelo componente Hero (site estático → new Date() do build ficaria
// congelado no dia do deploy). Aqui passamos o pool completo de candidatos + uma
// seleção por omissão (dia do build) para o primeiro paint sem flash de hidratação.
const hasOverview = (o) => ((o.details?.overview as string) || "").trim().length >= 40
const toSlide = (o) => ({
  region: o.region,
  title: offerTitle(o),
  dates: [o.country, o.nights ? `${o.nights} noites` : null, o.priceFrom ? `desde ${o.priceFrom}€` : null].filter(Boolean).join(" · "),
  image: offerImage(o.slug),
  href: `/ofertas/${o.slug}`,
  tagline: (o.details?.overview || `${o.type === "circuito" ? "Roteiro por" : "Férias em"} ${o.destino}, ${o.country}.`)
    .replace(/\s+/g, " ")
    .trim()
    .slice(0, 300),
})
// ordem base estável para que a escolha do build (servidor) e a do browser coincidam
// no dia do deploy (mesma seed + mesma base) — só divergem nos dias seguintes.
const eligible = offers
  .filter((o) => o.priceFrom && hasHeroImage(o.slug) && hasOverview(o))
  .sort((a, b) => a.slug.localeCompare(b.slug))
const heroPool = eligible.map(toSlide)
const heroPick = []
for (const o of shuffleByDay(eligible)) {
  if (!heroPick.some((x) => x.region === o.region)) heroPick.push(o)
  if (heroPick.length >= 5) break
}
const slides = heroPick.map(toSlide)
---

<Layout>
  <Header />
  <main>
    <Hero client:load slides={slides} pool={heroPool} />
    <Intro />
    <FeaturedTrips />
    <Distinguish />
    <Testimonials />
    <Newsletter />
    <DestinationsIndex />
  </main>
  <Footer />
</Layout>
