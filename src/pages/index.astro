---
import Layout from "../layouts/Layout.astro"
import Header from "../components/Header.astro"
import Hero from "../components/Hero.tsx"
import Intro from "../components/Intro.astro"
import FeaturedTrips from "../components/FeaturedTrips.astro"
import Distinguish from "../components/Distinguish.astro"
import Testimonials from "../components/Testimonials.astro"
import Newsletter from "../components/Newsletter.astro"
import DestinationsIndex from "../components/DestinationsIndex.astro"
import Footer from "../components/Footer.astro"
import { offers, offerImage, hasHeroImage, shuffleByDay } from "../data/offers"

// slides do hero: uma oferta por região, escolhida ALEATORIAMENTE entre as que
// têm imagem de qualidade (≥1500px) e descrição própria. A seleção roda a cada
// dia (seed do dia, recalculada no build) — ninguém escolhe os destinos à mão.
const hasOverview = (o) => ((o.details?.overview as string) || "").trim().length >= 40
const heroPick = []
for (const o of shuffleByDay(offers)) {
  if (!o.priceFrom || !hasHeroImage(o.slug) || !hasOverview(o)) continue
  if (!heroPick.some((x) => x.region === o.region)) heroPick.push(o)
  if (heroPick.length >= 5) break
}
const slides = heroPick.map((o) => ({
  title: o.destino,
  dates: [o.country, o.nights ? `${o.nights} noites` : null, o.priceFrom ? `desde ${o.priceFrom}€` : null].filter(Boolean).join(" · "),
  image: offerImage(o.slug),
  href: `/ofertas/${o.slug}`,
  tagline: (o.details?.overview || `${o.type === "circuito" ? "Roteiro por" : "Férias em"} ${o.destino}, ${o.country}.`)
    .replace(/\s+/g, " ")
    .trim()
    .slice(0, 300),
}))
---

<Layout>
  <Header />
  <main>
    <Hero client:load slides={slides} />
    <Intro />
    <FeaturedTrips />
    <Distinguish />
    <Testimonials />
    <Newsletter />
    <DestinationsIndex />
  </main>
  <Footer />
</Layout>
