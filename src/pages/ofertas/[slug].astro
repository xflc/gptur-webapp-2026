---
import Layout from "../../layouts/Layout.astro"
import Header from "../../components/Header.astro"
import Footer from "../../components/Footer.astro"
import OfferCard from "../../components/OfferCard.astro"
import { offers, offerImage, boardLabel } from "../../data/offers"
import { Calendar, BedDouble, Utensils, MapPin, Phone } from "lucide-react"

export function getStaticPaths() {
  return offers.map((offer) => ({ params: { slug: offer.slug }, props: { offer } }))
}
const { offer } = Astro.props
const related = offers.filter((o) => o.region === offer.region && o.slug !== offer.slug).slice(0, 3)

const pageTitle = `${offer.destino}, ${offer.country} | GPTur`
const desc = `${offer.destino} (${offer.country}) — ${offer.type === "circuito" ? "circuito" : "estadia"}${offer.priceFrom ? `, desde ${offer.priceFrom}€ por pessoa` : ""}. Reserve com a GPTur.`

const jsonLd = {
  "@context": "https://schema.org", "@type": "TouristTrip",
  name: `${offer.destino}, ${offer.country}`, description: desc, image: offerImage(offer.slug),
  ...(offer.priceFrom ? { offers: { "@type": "Offer", price: offer.priceFrom, priceCurrency: "EUR" } } : {}),
  provider: { "@type": "TravelAgency", name: "GPTur — Companhia das Viagens" },
}
---

<Layout title={pageTitle} description={desc}>
  <Header />
  <main>
    <section class="relative h-[46vh] min-h-[340px] w-full overflow-hidden bg-ink">
      <img src={offerImage(offer.slug)} alt={offer.destino} class="h-full w-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/35 to-black/15"></div>
      <div class="absolute inset-0 flex items-end">
        <div class="mx-auto w-full max-w-7xl px-5 pb-9 lg:px-8">
          <nav class="mb-3 flex flex-wrap items-center gap-2 text-xs text-white/70">
            <a href="/" class="hover:text-white">Início</a><span>/</span>
            <a href="/catalogo" class="hover:text-white">Catálogo</a><span>/</span>
            <span class="text-white/90">{offer.destino}</span>
          </nav>
          <div class="flex flex-wrap items-center gap-2">
            <span class="eyebrow bg-accent px-2.5 py-1 text-[0.6rem] text-accent-foreground">{offer.type === "circuito" ? "Circuito" : "Estadia"}</span>
            <span class="eyebrow bg-white/15 px-2.5 py-1 text-[0.6rem] text-white backdrop-blur">{offer.region}</span>
          </div>
          <h1 class="mt-3 font-display text-4xl leading-tight text-white sm:text-5xl">{offer.destino}</h1>
          <p class="mt-1 text-white/85">{offer.country}</p>
        </div>
      </div>
    </section>

    <section class="bg-white py-14">
      <div class="mx-auto grid max-w-7xl gap-12 px-5 lg:grid-cols-[1fr_340px] lg:px-8">
        <div>
          <p class="text-[0.98rem] leading-relaxed text-foreground/85">
            {offer.type === "circuito"
              ? `Circuito em ${offer.destino}${offer.nights ? `, ${offer.nights} noites` : ""}, com voos, transferes e alojamento. Consulte-nos para o itinerário detalhado e datas de partida.`
              : `Estadia em ${offer.destino}${offer.nights ? `, ${offer.nights} noites` : ""}, com voos e transferes incluídos. ${offer.hotels ? `${offer.hotels} hotéis à escolha` : ""}${offer.boards?.length ? `, em regime de ${offer.boards.map(boardLabel).join(", ")}.` : "."}`}
          </p>
          <p class="mt-4 rounded-lg border border-border bg-cream p-5 text-sm text-muted-foreground">
            Programa detalhado, hotéis e preços por data sob consulta — a nossa equipa envia-lhe a proposta completa à medida.
          </p>

          {related.length > 0 && (
            <div class="mt-12">
              <h2 class="mb-6 font-display text-2xl text-ink">Outras viagens em {offer.region}</h2>
              <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
                {related.map((o) => <OfferCard offer={o} />)}
              </div>
            </div>
          )}
        </div>

        <aside>
          <div class="sticky top-24 rounded-xl border border-border bg-card p-6 shadow-sm">
            <div class="space-y-4 border-b border-border pb-5">
              {offer.nights && (
                <div class="flex items-start gap-3"><Calendar size={18} className="mt-0.5 shrink-0 text-primary" /><div><p class="eyebrow text-[0.58rem] text-muted-foreground">Duração</p><p class="text-sm font-medium">{offer.nights} noites</p></div></div>
              )}
              {offer.hotels && (
                <div class="flex items-start gap-3"><BedDouble size={18} className="mt-0.5 shrink-0 text-primary" /><div><p class="eyebrow text-[0.58rem] text-muted-foreground">Alojamento</p><p class="text-sm font-medium">{offer.hotels} hotéis à escolha</p></div></div>
              )}
              {offer.boards?.length ? (
                <div class="flex items-start gap-3"><Utensils size={18} className="mt-0.5 shrink-0 text-primary" /><div><p class="eyebrow text-[0.58rem] text-muted-foreground">Regime</p><p class="text-sm font-medium">{offer.boards.map(boardLabel).join(", ")}</p></div></div>
              ) : null}
              <div class="flex items-start gap-3"><MapPin size={18} className="mt-0.5 shrink-0 text-primary" /><div><p class="eyebrow text-[0.58rem] text-muted-foreground">Destino</p><p class="text-sm font-medium">{offer.destino}, {offer.country}</p></div></div>
            </div>
            {offer.priceFrom && (
              <div class="pt-5">
                <p class="text-[0.65rem] text-muted-foreground">preço por pessoa, desde</p>
                <p class="font-display text-4xl font-semibold text-primary">{offer.priceFrom.toLocaleString("pt-PT")} €</p>
              </div>
            )}
            <a href={`mailto:reservas@gptur.pt?subject=Reserva: ${offer.destino}, ${offer.country}`} class="mt-5 flex h-12 w-full items-center justify-center rounded-md bg-primary text-sm font-semibold uppercase tracking-widest text-primary-foreground transition-colors hover:bg-teal-700">Reservar / Pedir proposta</a>
            <a href="tel:+351217530021" class="mt-2.5 flex h-11 w-full items-center justify-center gap-2 rounded-md border border-primary text-sm font-semibold text-primary transition-colors hover:bg-primary hover:text-primary-foreground"><Phone size={16} /> 217 530 021</a>
          </div>
        </aside>
      </div>
    </section>
  </main>
  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</Layout>
