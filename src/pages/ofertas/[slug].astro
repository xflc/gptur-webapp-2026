---
import Layout from "../../layouts/Layout.astro"
import Header from "../../components/Header.astro"
import Footer from "../../components/Footer.astro"
import OfferCard from "../../components/OfferCard.astro"
import { offers, offerImage, boardLabel } from "../../data/offers"
import { Calendar, BedDouble, Utensils, MapPin, Phone, Plane, Check, Star } from "lucide-react"

export function getStaticPaths() {
  return offers.map((offer) => ({ params: { slug: offer.slug }, props: { offer } }))
}
const { offer } = Astro.props
const d = offer.details ?? {}
const hotels = d.hotels ?? []
const routes = d.routes ?? []
const related = offers.filter((o) => o.region === offer.region && o.slug !== offer.slug).slice(0, 3)

const included = [
  "Voos ida e volta com taxas incluídas",
  "Transferes aeroporto / hotel / aeroporto",
  offer.nights ? `${offer.nights} noites de alojamento no hotel escolhido` : "Alojamento no hotel escolhido",
  offer.boards?.length ? `Regime de ${offer.boards.map(boardLabel).join(" / ")}` : null,
  "Seguro de viagem",
].filter(Boolean)

const pageTitle = `${offer.destino}, ${offer.country} | GPTur`
const desc = `${offer.destino} (${offer.country}) — ${offer.type === "circuito" ? "circuito" : "estadia"}${offer.priceFrom ? `, desde ${offer.priceFrom}€ por pessoa` : ""}. Reserve com a GPTur.`
const jsonLd = {
  "@context": "https://schema.org", "@type": "TouristTrip",
  name: `${offer.destino}, ${offer.country}`, description: desc, image: offerImage(offer.slug),
  ...(offer.priceFrom ? { offers: { "@type": "Offer", price: offer.priceFrom, priceCurrency: "EUR" } } : {}),
  provider: { "@type": "TravelAgency", name: "GPTur — Companhia das Viagens" },
}
---

<Layout title={pageTitle} description={desc}>
  <Header />
  <main>
    <!-- Hero -->
    <section class="relative h-[46vh] min-h-[340px] w-full overflow-hidden bg-ink">
      <img src={offerImage(offer.slug)} alt={offer.destino} class="h-full w-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/35 to-black/15"></div>
      <div class="absolute inset-0 flex items-end">
        <div class="mx-auto w-full max-w-7xl px-5 pb-9 lg:px-8">
          <nav class="mb-3 flex flex-wrap items-center gap-2 text-xs text-white/70">
            <a href="/" class="hover:text-white">Início</a><span>/</span>
            <a href="/catalogo" class="hover:text-white">Catálogo</a><span>/</span>
            <span class="text-white/90">{offer.destino}</span>
          </nav>
          <div class="flex flex-wrap items-center gap-2">
            <span class="eyebrow bg-accent px-2.5 py-1 text-[0.6rem] text-accent-foreground">{offer.type === "circuito" ? "Circuito" : "Estadia"}</span>
            <span class="eyebrow bg-white/15 px-2.5 py-1 text-[0.6rem] text-white backdrop-blur">{offer.region}</span>
          </div>
          <h1 class="mt-3 font-display text-4xl leading-tight text-white sm:text-5xl">{offer.destino}</h1>
          <p class="mt-1 text-white/85">{offer.country}</p>
        </div>
      </div>
    </section>

    <!-- Body -->
    <section class="bg-white py-14">
      <div class="mx-auto grid max-w-7xl gap-12 px-5 lg:grid-cols-[1fr_340px] lg:px-8">
        <div>
          {d.overview && <p class="text-[0.98rem] leading-relaxed text-foreground/85">{d.overview}</p>}

          <!-- Inclui -->
          <div class="my-8 rounded-xl border border-border bg-cream p-6">
            <h2 class="font-display text-2xl text-ink">O que inclui</h2>
            <ul class="mt-4 grid gap-2.5 sm:grid-cols-2">
              {included.map((item) => (
                <li class="flex gap-2.5 text-sm text-foreground/80">
                  <Check size={18} className="mt-0.5 shrink-0 text-primary" /><span>{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Circuito: itinerário -->
          {offer.type === "circuito" && routes.length > 0 && (
            <div class="mt-10">
              <h2 class="mb-6 font-display text-3xl text-ink">Itinerário</h2>
              <ol class="space-y-0">
                {routes.map((r, i) => (
                  <li class="relative flex gap-5 pb-7 last:pb-0">
                    {i < routes.length - 1 && <span class="absolute left-[19px] top-10 h-full w-px bg-border" />}
                    <span class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-teal-50 text-xs font-bold text-primary ring-1 ring-teal-200">{i + 1}</span>
                    <div class="pt-1.5">
                      <p class="eyebrow text-[0.62rem] text-gold-500">{r.day}</p>
                      <h4 class="mt-0.5 font-display text-lg text-ink">{r.route}</h4>
                    </div>
                  </li>
                ))}
              </ol>
              <p class="mt-4 text-sm text-muted-foreground">Descrição detalhada de cada dia e datas de partida sob consulta.</p>
            </div>
          )}

          <!-- Estadia: tabela de hotéis -->
          {offer.type === "estadia" && hotels.length > 0 && (
            <div class="mt-10">
              <h2 class="mb-1 font-display text-3xl text-ink">Hotéis à escolha</h2>
              <p class="mb-5 text-sm text-muted-foreground">Preços indicativos por pessoa em quarto duplo.</p>
              <div class="overflow-hidden rounded-xl border border-border">
                <table class="w-full text-sm">
                  <thead class="bg-secondary">
                    <tr class="text-left text-[0.7rem] uppercase tracking-wide text-muted-foreground">
                      <th class="px-4 py-3 font-semibold">Hotel</th>
                      <th class="px-4 py-3 font-semibold">Regime</th>
                      <th class="px-4 py-3 text-right font-semibold">Desde</th>
                    </tr>
                  </thead>
                  <tbody>
                    {hotels.map((h) => (
                      <tr class="border-t border-border">
                        <td class="px-4 py-3">
                          <span class="font-medium text-foreground">{h.name.replace(/\s*\d\*?$/, "")}</span>
                          <span class="ml-1 inline-flex items-center gap-0.5 align-middle text-gold-400">
                            {Array.from({ length: h.stars }).map(() => <Star size={11} className="fill-current" />)}
                          </span>
                        </td>
                        <td class="px-4 py-3 text-muted-foreground">{h.board ? boardLabel(h.board) : "—"}{h.nights ? ` · ${h.nights}N` : ""}</td>
                        <td class="px-4 py-3 text-right font-semibold text-primary">{h.price ? h.price.toLocaleString("pt-PT") + " €" : "sob consulta"}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          )}

          <p class="mt-8 rounded-lg border border-border bg-cream p-5 text-sm text-muted-foreground">
            Preços e disponibilidade por data sob consulta — a nossa equipa envia-lhe a proposta completa à medida.
          </p>
        </div>

        <!-- Sidebar -->
        <aside>
          <div class="sticky top-24 rounded-xl border border-border bg-card p-6 shadow-sm">
            <div class="space-y-4 border-b border-border pb-5">
              {offer.nights && <div class="flex items-start gap-3"><Calendar size={18} className="mt-0.5 shrink-0 text-primary" /><div><p class="eyebrow text-[0.58rem] text-muted-foreground">Duração</p><p class="text-sm font-medium">{offer.nights} noites</p></div></div>}
              {offer.type === "estadia" && offer.hotels && <div class="flex items-start gap-3"><BedDouble size={18} className="mt-0.5 shrink-0 text-primary" /><div><p class="eyebrow text-[0.58rem] text-muted-foreground">Alojamento</p><p class="text-sm font-medium">{offer.hotels} hotéis à escolha</p></div></div>}
              {offer.boards?.length ? <div class="flex items-start gap-3"><Utensils size={18} className="mt-0.5 shrink-0 text-primary" /><div><p class="eyebrow text-[0.58rem] text-muted-foreground">Regime</p><p class="text-sm font-medium">{offer.boards.map(boardLabel).join(", ")}</p></div></div> : null}
              <div class="flex items-start gap-3"><Plane size={18} className="mt-0.5 shrink-0 text-primary" /><div><p class="eyebrow text-[0.58rem] text-muted-foreground">Voos</p><p class="text-sm font-medium">Incluídos (ida e volta)</p></div></div>
              <div class="flex items-start gap-3"><MapPin size={18} className="mt-0.5 shrink-0 text-primary" /><div><p class="eyebrow text-[0.58rem] text-muted-foreground">Destino</p><p class="text-sm font-medium">{offer.destino}, {offer.country}</p></div></div>
            </div>
            {offer.priceFrom && (
              <div class="pt-5">
                <p class="text-[0.65rem] text-muted-foreground">preço por pessoa, desde</p>
                <p class="font-display text-4xl font-semibold text-primary">{offer.priceFrom.toLocaleString("pt-PT")} €</p>
              </div>
            )}
            <a href={`mailto:reservas@gptur.pt?subject=Reserva: ${offer.destino}, ${offer.country}`} class="mt-5 flex h-12 w-full items-center justify-center rounded-md bg-primary text-sm font-semibold uppercase tracking-widest text-primary-foreground transition-colors hover:bg-teal-700">Reservar / Pedir proposta</a>
            <a href="tel:+351217530021" class="mt-2.5 flex h-11 w-full items-center justify-center gap-2 rounded-md border border-primary text-sm font-semibold text-primary transition-colors hover:bg-primary hover:text-primary-foreground"><Phone size={16} /> 217 530 021</a>
          </div>
        </aside>
      </div>
    </section>

    {related.length > 0 && (
      <section class="bg-cream py-16">
        <div class="mx-auto max-w-7xl px-5 lg:px-8">
          <h2 class="mb-8 font-display text-3xl text-ink">Outras viagens em {offer.region}</h2>
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">{related.map((o) => <OfferCard offer={o} />)}</div>
        </div>
      </section>
    )}
  </main>
  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</Layout>
