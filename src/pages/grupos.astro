---
import Layout from "../layouts/Layout.astro"
import Header from "../components/Header.astro"
import Footer from "../components/Footer.astro"
import PageBanner from "../components/PageBanner.astro"
import { MapPin, CalendarDays, Users } from "lucide-react"
import { readdirSync } from "node:fs"
import { resolve } from "node:path"

// todas as fotos de uma pasta public/groups/<dir> (ordem numérica: 1,2,…,10)
const listImages = (dir: string) => {
  try {
    return readdirSync(resolve("public/groups", dir))
      .filter((f) => /\.(jpe?g|png)$/i.test(f))
      .sort((a, b) => a.localeCompare(b, undefined, { numeric: true }))
      .map((f) => `/groups/${dir}/${f}`)
  } catch {
    return []
  }
}

// Viagens de grupo, mais recentes primeiro. A timeline agrupa por ano.
// Para adicionar uma viagem: nova entrada com year, cover, gallery e testemunhos.
// (sample: true → entrada de exemplo, mostra o selo "Exemplo" — substituir.)
const trips = [
  {
    year: 2026,
    title: "Viagem às raízes de Santo Inácio",
    tag: "Espanha",
    dates: "14–18 fev",
    people: "54 peregrinos",
    route: "Loiola · Manresa · Montserrat · Barcelona",
    dir: "santo-inacio",
    blurb:
      "Uma peregrinação por Espanha nas raízes espirituais de Santo Inácio de Loiola — de Loiola a Manresa e Montserrat, até à Sagrada Família em Barcelona. 54 peregrinos, entre história, arte e paisagem.",
    testimonials: [
      {
        quote:
          "Foram cinco dias a caminhar e a partilhar em grupo. De Loiola a Manresa e Montserrat, cada lugar deixou de ser um ponto no mapa para se tornar parte da nossa própria história. Voltámos mais leves e mais unidos — e gratos pela forma cuidada como tudo foi preparado.",
        author: "Testemunho de exemplo",
        role: "substituir",
      },
      {
        quote:
          "Nunca tinha viajado com um grupo tão grande e receava a logística. No fim, só tive de me deixar guiar: transferes, hotéis, horários — estava tudo pensado ao pormenor, o que nos deixou livres para viver a experiência.",
        author: "Testemunho de exemplo",
        role: "substituir",
      },
    ],
  },
  {
    year: 2024,
    title: "Nos passos de São Paulo",
    tag: "Grécia & Turquia",
    dates: "26 mai–5 jun",
    people: "48 peregrinos",
    route: "Grécia · Turquia · Éfeso",
    dir: "sao-paulo-22",
    blurb:
      "Uma peregrinação pela Grécia e Turquia à volta das origens do cristianismo, seguindo os caminhos por onde São Paulo viajou — de teatros e ruínas antigas às paisagens do Egeu, entre sítios arqueológicos, história e conversa em grupo.",
    testimonials: [
      {
        quote:
          "Percorrer estes lugares tornou vivo aquilo que só conhecíamos dos livros. Entre ruínas, mar e boas conversas, foi uma viagem que ligou história e presente de uma forma que não esperava.",
        author: "Testemunho de exemplo",
        role: "substituir",
      },
      {
        quote:
          "Grécia e Turquia num só percurso, com tudo tratado ao pormenor. Só tivemos de aparecer e deixar-nos levar — do primeiro sítio arqueológico ao último pôr do sol no barco.",
        author: "Testemunho de exemplo",
        role: "substituir",
      },
    ],
  },
  {
    year: 2022,
    title: "Da Roma eterna para o mundo de hoje",
    tag: "Itália",
    dates: "4–9 out",
    people: "52 viajantes",
    route: "Roma · Vaticano · Gesù",
    dir: "da-roma-eterna",
    blurb:
      "A primeira viagem de grupo que organizámos: 52 viajantes rumaram a Roma para uma “viagem em forma de conversa” — do Coliseu ao Vaticano e à Igreja do Gesù, entre a beleza da arte, encontros com convidados e o convívio do grupo.",
    testimonials: [
      {
        quote:
          "Roma abriu-se a nós não como um museu, mas como uma conversa viva — com a história, com a arte e com os convidados que nos foram cruzando o caminho. Regressei com perguntas melhores do que aquelas com que parti.",
        author: "Testemunho de exemplo",
        role: "substituir",
      },
      {
        quote:
          "Foi a primeira viagem de grupo que organizaram e ficou marcada em todos nós: cinco dias entre a beleza da Cidade Eterna e a companhia do grupo, sem termos de nos preocupar com nada da organização.",
        author: "Testemunho de exemplo",
        role: "substituir",
      },
    ],
  },
]

// Para cada viagem: descobre as imagens (pasta `dir` ou capa única), define
// capa, as 4 miniaturas do preview e quantas fotos extra existem (+N).
// O lightbox recebe SEMPRE o conjunto completo (`images`).
trips.forEach((t, i) => {
  t.id = i
  t.images = t.dir ? listImages(t.dir) : [t.cover, ...(t.gallery || [])]
  t.cover = t.images[0]
  t.thumbs = t.images.slice(1, 5) // até 4 miniaturas
  t.extra = Math.max(0, t.images.length - 5) // fotos não previstas no preview
})
const galleries = trips.map((t) => t.images)
const years = [...new Set(trips.map((t) => t.year))].sort((a, b) => b - a)
---

<Layout
  title="Grupos | GPTur · Companhia das Viagens"
  description="Viagens de grupo organizadas pela GPTur — peregrinações e viagens temáticas à medida, ano a ano, com testemunhos de quem viajou connosco."
>
  <Header />
  <main>
    <PageBanner
      eyebrow="Viagens que organizámos"
      title="Grupos"
      subtitle="Organizamos viagens de grupo de ponta a ponta — peregrinações, viagens temáticas e culturais. Ano a ano, um percurso de grupos que viajaram connosco."
      crumb="Grupos"
    />

    <section class="bg-white py-14">
      <div class="mx-auto max-w-5xl px-5 lg:px-8">
        {
          years.map((year) => (
            <div class="mb-12">
              <div class="mb-6 flex items-center gap-4">
                <span class="font-display text-3xl text-ink">{year}</span>
                <span class="h-px flex-1 bg-border" />
              </div>

              <div class="space-y-8 border-l-2 border-border pl-6 sm:pl-10">
                {trips
                  .filter((t) => t.year === year)
                  .map((t) => (
                    <article class="relative overflow-hidden rounded-2xl border border-border bg-white shadow-sm">
                      <span class="absolute -left-[calc(1.5rem+8px)] top-8 h-3.5 w-3.5 rounded-full border-2 border-white bg-primary sm:-left-[calc(2.5rem+8px)]" />

                      {/* topo: imagem preenche a altura da coluna de texto (sem espaço morto) */}
                      <div class="grid sm:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)]">
                        <div class="relative min-h-[220px]">
                          <img
                            src={t.cover}
                            alt={t.title}
                            class="absolute inset-0 h-full w-full cursor-zoom-in object-cover"
                            loading="lazy"
                            data-lb
                            data-g={t.id}
                            data-i="0"
                          />
                          {t.sample && (
                            <span class="absolute left-3 top-3 rounded bg-black/60 px-2 py-0.5 text-[0.6rem] uppercase tracking-widest text-white">
                              Exemplo
                            </span>
                          )}
                        </div>

                        <div class="p-6 lg:p-7">
                          <span class="eyebrow text-[0.62rem] text-gold-500">{t.tag}</span>
                          <h3 class="mt-1 font-display text-2xl leading-tight text-ink">{t.title}</h3>
                          <div class="mt-3 flex flex-wrap gap-x-4 gap-y-1.5 text-xs text-muted-foreground">
                            <span class="flex items-center gap-1.5"><CalendarDays size={13} className="text-primary" /> {t.dates}</span>
                            <span class="flex items-center gap-1.5"><Users size={13} className="text-primary" /> {t.people}</span>
                            <span class="flex items-center gap-1.5"><MapPin size={13} className="text-primary" /> {t.route}</span>
                          </div>
                          <p class="mt-3 text-sm leading-relaxed text-foreground/80">{t.blurb}</p>

                          {t.thumbs.length > 0 && (
                            <div class="mt-4 flex flex-wrap gap-2">
                              {t.thumbs.map((img, gi) => (
                                <button type="button" class="relative block cursor-zoom-in overflow-hidden rounded" data-lb data-g={t.id} data-i={gi + 1}>
                                  <img src={img} alt={t.title} class="h-16 w-24 object-cover transition-transform duration-300 hover:scale-110" loading="lazy" />
                                  {t.extra > 0 && gi === t.thumbs.length - 1 && (
                                    <span class="absolute inset-0 grid place-items-center bg-black/55 text-sm font-semibold text-white">+{t.extra}</span>
                                  )}
                                </button>
                              ))}
                            </div>
                          )}
                        </div>
                      </div>

                      {/* testemunhos: pull-quotes a toda a largura, podem ser um parágrafo */}
                      {t.testimonials?.length > 0 && (
                        <div class="border-t border-border bg-cream/60 px-6 py-6 lg:px-7">
                          <div class="grid gap-x-10 gap-y-6 md:grid-cols-2">
                            {t.testimonials.map((tt) => (
                              <figure class="relative pl-7">
                                <span class="absolute -top-2 left-0 font-display text-4xl leading-none text-gold-300" aria-hidden="true">“</span>
                                <blockquote class="text-[0.95rem] italic leading-relaxed text-foreground/80">{tt.quote}</blockquote>
                                <figcaption class="mt-2.5 text-xs text-muted-foreground">
                                  <span class="font-semibold not-italic text-foreground/70">{tt.author}</span>
                                  {tt.role && <span> · {tt.role}</span>}
                                </figcaption>
                              </figure>
                            ))}
                          </div>
                        </div>
                      )}
                    </article>
                  ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <section class="bg-teal-800 py-14 text-white">
      <div class="mx-auto flex max-w-4xl flex-col items-center gap-6 px-5 text-center lg:flex-row lg:justify-between lg:text-left lg:px-8">
        <div>
          <h2 class="font-display text-2xl text-white sm:text-3xl">Quer organizar uma viagem de grupo?</h2>
          <p class="mt-2 text-white/80">
            Comunidades, paróquias, escolas ou empresas — desenhamos o programa consigo, do primeiro contacto ao regresso.
          </p>
        </div>
        <a
          href="/contactos"
          class="flex h-12 shrink-0 items-center justify-center rounded-md bg-accent px-6 text-sm font-semibold uppercase tracking-widest text-accent-foreground transition-colors hover:bg-gold-400"
          >Falar connosco</a
        >
      </div>
    </section>

    {/* Lightbox: clicar numa foto abre-a; setas ‹ › (e teclado) percorrem a viagem */}
    <div
      id="lightbox"
      class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/90 p-4 select-none"
      role="dialog"
      aria-modal="true"
    >
      <button id="lb-close" aria-label="Fechar" class="absolute right-4 top-4 grid h-11 w-11 place-items-center rounded-full bg-white/10 text-2xl text-white transition-colors hover:bg-white/20">✕</button>
      <button id="lb-prev" aria-label="Anterior" class="absolute left-3 top-1/2 grid h-12 w-12 -translate-y-1/2 place-items-center rounded-full bg-white/10 text-3xl text-white transition-colors hover:bg-white/20 sm:left-6">‹</button>
      <img id="lb-img" src="" alt="" class="max-h-[86vh] max-w-[92vw] rounded-lg object-contain shadow-2xl" />
      <button id="lb-next" aria-label="Seguinte" class="absolute right-3 top-1/2 grid h-12 w-12 -translate-y-1/2 place-items-center rounded-full bg-white/10 text-3xl text-white transition-colors hover:bg-white/20 sm:right-6">›</button>
      <div id="lb-count" class="absolute bottom-5 left-1/2 -translate-x-1/2 rounded-full bg-black/50 px-3 py-1 text-xs tracking-widest text-white/80"></div>
    </div>
    <script id="lb-data" type="application/json" set:html={JSON.stringify(galleries)} />
  </main>
  <Footer />
</Layout>

<script>
  const galleries = JSON.parse(document.getElementById("lb-data")!.textContent!)
  const lb = document.getElementById("lightbox")!
  const img = document.getElementById("lb-img") as HTMLImageElement
  const count = document.getElementById("lb-count")!
  const prev = document.getElementById("lb-prev")!
  const next = document.getElementById("lb-next")!
  let g = 0, i = 0

  function render() {
    const arr = galleries[g]
    img.src = arr[i]
    count.textContent = `${i + 1} / ${arr.length}`
    const multi = arr.length > 1
    prev.hidden = next.hidden = !multi
    count.hidden = !multi
  }
  function open(gi: number, ii: number) {
    g = gi; i = ii
    lb.classList.remove("hidden"); lb.classList.add("flex")
    document.body.style.overflow = "hidden"
    render()
  }
  function close() {
    lb.classList.add("hidden"); lb.classList.remove("flex")
    document.body.style.overflow = ""
  }
  function step(d: number) {
    const arr = galleries[g]
    i = (i + d + arr.length) % arr.length
    render()
  }

  document.querySelectorAll<HTMLElement>("[data-lb]").forEach((el) =>
    el.addEventListener("click", () => open(Number(el.dataset.g), Number(el.dataset.i)))
  )
  document.getElementById("lb-close")!.addEventListener("click", close)
  prev.addEventListener("click", () => step(-1))
  next.addEventListener("click", () => step(1))
  lb.addEventListener("click", (e) => { if (e.target === lb) close() })
  document.addEventListener("keydown", (e) => {
    if (lb.classList.contains("hidden")) return
    if (e.key === "Escape") close()
    else if (e.key === "ArrowLeft") step(-1)
    else if (e.key === "ArrowRight") step(1)
  })
</script>
