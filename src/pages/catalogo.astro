---
import Layout from "../layouts/Layout.astro"
import Header from "../components/Header.astro"
import Footer from "../components/Footer.astro"
import PageBanner from "../components/PageBanner.astro"
import OfferCard from "../components/OfferCard.astro"
import { offers, offerRegions, shuffleByDay } from "../data/offers"

// ordem baralhada por dia — evita mostrar tudo do mesmo país/origem em bloco
const catalogo = shuffleByDay(offers)
---

<Layout
  title="Catálogo de Viagens | GPTur"
  description="Destinos únicos e roteiros por todo o mundo — filtre por região e encontre a viagem certa para si."
>
  <Header />
  <main>
    <PageBanner
      eyebrow={`${offers.length} viagens disponíveis`}
      title="Catálogo de Viagens"
      subtitle="Dos clássicos aos destinos mais invulgares — filtre por região e fale connosco para reservar."
      crumb="Catálogo de Viagens"
    />

    <section class="bg-white py-12">
      <div class="mx-auto max-w-7xl px-5 lg:px-8">
        <div class="mb-8 flex flex-wrap gap-2" id="region-filter">
          <button data-region="all" class="filter-chip rounded-full border border-primary bg-primary px-4 py-1.5 text-sm font-medium text-primary-foreground">Todas</button>
          {offerRegions.map((r) => (
            <button data-region={r} class="filter-chip rounded-full border border-border px-4 py-1.5 text-sm text-foreground/80 transition-colors hover:border-primary hover:text-primary">{r}</button>
          ))}
        </div>

        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3" id="grid">
          {catalogo.map((o) => (
            <div class="offer-item" data-region={o.region} data-type={o.type} data-price={o.priceFrom ?? ""}>
              <OfferCard offer={o} />
            </div>
          ))}
        </div>
        <p id="empty" class="hidden py-12 text-center text-muted-foreground">Sem viagens nesta região. Fale connosco para um circuito à medida.</p>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  const chips = document.querySelectorAll<HTMLButtonElement>(".filter-chip")
  const items = document.querySelectorAll<HTMLElement>(".offer-item")
  const empty = document.getElementById("empty")
  const on = ["border-primary", "bg-primary", "text-primary-foreground"]
  const off = ["border-border", "text-foreground/80"]

  // filtros vindos do finder da homepage (?regiao=&tipo=&max=)
  const params = new URLSearchParams(location.search)
  let region = params.get("regiao") || "all"
  const type = params.get("tipo") || ""
  const max = Number(params.get("max")) || Infinity

  function apply() {
    chips.forEach((c) => {
      const active = c.dataset.region === region
      c.classList.toggle("border-primary", active)
      c.classList.toggle("bg-primary", active)
      c.classList.toggle("text-primary-foreground", active)
      c.classList.toggle("border-border", !active)
      c.classList.toggle("text-foreground/80", !active)
    })
    let vis = 0
    items.forEach((it) => {
      const price = Number(it.dataset.price) || 0
      const m =
        (region === "all" || it.dataset.region === region) &&
        (!type || it.dataset.type === type) &&
        (max === Infinity || (price > 0 && price <= max))
      it.classList.toggle("hidden", !m)
      if (m) vis++
    })
    empty?.classList.toggle("hidden", vis > 0)
  }

  chips.forEach((chip) =>
    chip.addEventListener("click", () => { region = chip.dataset.region!; apply() })
  )
  apply() // aplica filtros iniciais (do finder ou nenhum)
</script>
