---
import Layout from "../../layouts/Layout.astro"
import Header from "../../components/Header.astro"
import Footer from "../../components/Footer.astro"
import TripProgram from "../../components/TripProgram.tsx"
import TripCard from "../../components/TripCard.astro"
import { trips } from "../../data/trips"
import { Calendar, Clock, Users, Utensils, Check, Download, Phone } from "lucide-react"

export function getStaticPaths() {
  return trips.map((trip) => ({
    params: { slug: trip.slug },
    props: { trip },
  }))
}

const { trip } = Astro.props
const d = trip.details
const related = trips
  .filter((t) => t.region === trip.region && t.slug !== trip.slug)
  .slice(0, 3)

const pageTitle = `${trip.title} | GPTur`
const pageDesc = trip.tagline

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "TouristTrip",
  name: trip.title,
  description: trip.tagline,
  image: trip.image,
  touristType: "Viagem cultural em grupo",
  offers: {
    "@type": "Offer",
    price: trip.price,
    priceCurrency: "EUR",
    availability: "https://schema.org/InStock",
  },
  provider: {
    "@type": "TravelAgency",
    name: "GPTur",
    url: "https://www.gptur.pt",
  },
}
---

<Layout title={pageTitle} description={pageDesc}>
  <Header />

  <main>
    <!-- Hero -->
    <section class="relative h-[52vh] min-h-[380px] w-full overflow-hidden bg-ink">
      <img src={trip.image} alt={trip.title} class="h-full w-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/35 to-black/20"></div>
      <div class="absolute inset-0 flex items-end">
        <div class="mx-auto w-full max-w-7xl px-5 pb-10 lg:px-8">
          <nav class="mb-3 flex flex-wrap items-center gap-2 text-xs text-white/70">
            <a href="/" class="hover:text-white">Início</a>
            <span>/</span>
            <a href="/#ofertas" class="hover:text-white">Catálogo</a>
            <span>/</span>
            <span class="text-white/90">{trip.title}</span>
          </nav>
          <div class="flex flex-wrap items-center gap-2">
            <span class="eyebrow bg-accent px-2.5 py-1 text-[0.6rem] text-accent-foreground">{trip.region}</span>
            {d?.groupTravel && (
              <span class="eyebrow bg-white/15 px-2.5 py-1 text-[0.6rem] text-white backdrop-blur">Viagem em grupo</span>
            )}
            {trip.withAuthor && (
              <span class="eyebrow bg-white/15 px-2.5 py-1 text-[0.6rem] text-white backdrop-blur">Com Autor</span>
            )}
          </div>
          <h1 class="mt-3 max-w-3xl font-display text-4xl leading-tight text-white sm:text-5xl">{trip.title}</h1>
          <p class="mt-2 max-w-xl text-white/85">{trip.tagline}</p>
        </div>
      </div>
    </section>

    <!-- Body -->
    <section class="bg-white py-14">
      <div class="mx-auto grid max-w-7xl gap-12 px-5 lg:grid-cols-[1fr_340px] lg:px-8">
        <!-- Main column -->
        <div>
          {d ? (
            <>
              {d.overview.map((p) => (
                <p class="mb-4 text-[0.98rem] leading-relaxed text-foreground/85">{p}</p>
              ))}

              {d.highlights && (
                <div class="my-8 rounded-xl border border-border bg-cream p-6">
                  <h2 class="font-display text-2xl text-ink">Pontos altos</h2>
                  <ul class="mt-4 grid gap-2.5 sm:grid-cols-2">
                    {d.highlights.map((h) => (
                      <li class="flex gap-2.5 text-sm text-foreground/80">
                        <Check size={18} className="mt-0.5 shrink-0 text-primary" />
                        <span>{h}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              {d.otherDates && (
                <div class="my-8">
                  <h2 class="eyebrow text-gold-500">Outras datas</h2>
                  <ul class="mt-3 flex flex-wrap gap-2">
                    {d.otherDates.map((date) => (
                      <li class="rounded-full border border-border bg-secondary px-3.5 py-1.5 text-sm text-foreground/80">{date}</li>
                    ))}
                  </ul>
                </div>
              )}

              <div class="mt-10">
                <h2 class="mb-1 font-display text-3xl text-ink">Programa</h2>
                <p class="mb-2 text-sm text-muted-foreground">Consulte o itinerário e as condições da viagem.</p>
                <TripProgram client:visible details={d} />
              </div>

              {d.gallery && (
                <div class="mt-12">
                  <h2 class="mb-4 font-display text-3xl text-ink">Galeria</h2>
                  <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
                    {d.gallery.map((src) => (
                      <img src={src} alt={trip.title} loading="lazy" class="aspect-square w-full rounded-lg object-cover" />
                    ))}
                  </div>
                </div>
              )}
            </>
          ) : (
            <div>
              <p class="text-[0.98rem] leading-relaxed text-foreground/85">{trip.tagline}</p>
              <p class="mt-4 rounded-lg border border-border bg-cream p-5 text-sm text-muted-foreground">
                O programa detalhado desta viagem estará disponível brevemente. Contacte-nos para receber o itinerário completo e as condições.
              </p>
            </div>
          )}
        </div>

        <!-- Sticky booking sidebar -->
        <aside class="lg:pl-2">
          <div class="sticky top-24 rounded-xl border border-border bg-card p-6 shadow-sm">
            <div class="space-y-4 border-b border-border pb-5">
              <div class="flex items-start gap-3">
                <Calendar size={18} className="mt-0.5 shrink-0 text-primary" />
                <div>
                  <p class="eyebrow text-[0.58rem] text-muted-foreground">Data</p>
                  <p class="text-sm font-medium text-foreground">{trip.dates}</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <Clock size={18} className="mt-0.5 shrink-0 text-primary" />
                <div>
                  <p class="eyebrow text-[0.58rem] text-muted-foreground">Duração</p>
                  <p class="text-sm font-medium text-foreground">{trip.durationDays} dias</p>
                </div>
              </div>
              {d?.meals && (
                <div class="flex items-start gap-3">
                  <Utensils size={18} className="mt-0.5 shrink-0 text-primary" />
                  <div>
                    <p class="eyebrow text-[0.58rem] text-muted-foreground">Refeições</p>
                    <p class="text-sm font-medium text-foreground">{d.meals}</p>
                  </div>
                </div>
              )}
              {d?.groupTravel && (
                <div class="flex items-start gap-3">
                  <Users size={18} className="mt-0.5 shrink-0 text-primary" />
                  <div>
                    <p class="eyebrow text-[0.58rem] text-muted-foreground">Formato</p>
                    <p class="text-sm font-medium text-foreground">Viagem em grupo</p>
                  </div>
                </div>
              )}
            </div>

            <div class="pt-5">
              <p class="text-[0.65rem] text-muted-foreground">preço por pessoa, desde</p>
              <p class="font-display text-4xl font-semibold text-primary">{trip.price.toLocaleString("pt-PT")} €</p>
            </div>

            <a
              href={`mailto:altalisboa@gptur.pt,lisboa@gptur.pt?subject=Reserva: ${trip.title}`}
              class="mt-5 flex h-12 w-full items-center justify-center rounded-md bg-primary text-sm font-semibold uppercase tracking-widest text-primary-foreground transition-colors hover:bg-teal-700"
            >
              Reservar já
            </a>
            <a
              href="tel:+351217530021"
              class="mt-2.5 flex h-11 w-full items-center justify-center gap-2 rounded-md border border-primary text-sm font-semibold text-primary transition-colors hover:bg-primary hover:text-primary-foreground"
            >
              <Phone size={16} /> 217 530 021
            </a>
            <button
              class="mt-2.5 flex h-10 w-full items-center justify-center gap-2 text-xs font-semibold uppercase tracking-widest text-muted-foreground transition-colors hover:text-primary"
              onclick="window.print()"
            >
              <Download size={15} /> Descarregar PDF
            </button>
          </div>
        </aside>
      </div>
    </section>

    {related.length > 0 && (
      <section class="bg-cream py-16">
        <div class="mx-auto max-w-7xl px-5 lg:px-8">
          <h2 class="mb-8 font-display text-3xl text-ink">Outros circuitos em {trip.region}</h2>
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {related.map((t) => <TripCard trip={t} />)}
          </div>
        </div>
      </section>
    )}
  </main>

  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</Layout>
