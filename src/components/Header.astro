---
const nav = [
  { label: "Ofertas", href: "#ofertas" },
  { label: "Viagens à Medida", href: "#finder" },
  { label: "A Nossa Identidade", href: "#identidade" },
  { label: "Empresas", href: "#empresas" },
  { label: "Contactos", href: "#contactos" },
]
---

<header class="sticky top-0 z-50 border-b border-border bg-cream/95 backdrop-blur">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-6 px-5 py-4 lg:px-8">
    <a href="#inicio" class="flex items-center gap-3">
      <svg width="34" height="34" viewBox="0 0 40 40" fill="none" class="shrink-0" aria-hidden="true">
        <circle cx="20" cy="20" r="18" fill="var(--teal-600)" />
        <circle cx="28.5" cy="13" r="4.2" fill="var(--gold-300)" />
        <path
          d="M4 24 C 14 16, 26 16, 36 24"
          stroke="#fff"
          stroke-width="1.6"
          fill="none"
          opacity="0.9"
        />
        <path
          d="M8 28.5 C 16 22, 24 22, 32 28.5"
          stroke="#fff"
          stroke-width="1.6"
          fill="none"
          opacity="0.55"
        />
      </svg>
      <span class="flex flex-col leading-none">
        <span class="text-2xl font-bold tracking-[0.18em] text-primary">GPTUR</span>
        <span class="eyebrow text-[0.55rem] text-muted-foreground">Companhia das Viagens</span>
      </span>
    </a>

    <nav class="hidden items-center gap-7 lg:flex">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="eyebrow text-[0.7rem] text-foreground/80 transition-colors hover:text-primary"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <a
      href="#contactos"
      class="hidden rounded-md bg-primary px-4 py-2 text-xs font-semibold uppercase tracking-widest text-primary-foreground transition-colors hover:bg-teal-700 lg:inline-block"
      >Reservar</a
    >

    <button
      id="mobile-toggle"
      class="grid h-10 w-10 place-items-center rounded-md text-primary lg:hidden"
      aria-label="Abrir menu"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>
  </div>

  <nav
    id="mobile-menu"
    class="hidden flex-col gap-1 border-t border-border bg-cream px-5 py-4 lg:hidden"
  >
    {
      nav.map((item) => (
        <a
          href={item.href}
          class="eyebrow rounded-md px-2 py-3 text-xs text-foreground/80 hover:bg-secondary"
        >
          {item.label}
        </a>
      ))
    }
  </nav>
</header>

<script>
  const toggle = document.getElementById("mobile-toggle")
  const menu = document.getElementById("mobile-menu")
  toggle?.addEventListener("click", () => menu?.classList.toggle("hidden"))
  menu?.querySelectorAll("a").forEach((a) =>
    a.addEventListener("click", () => menu?.classList.add("hidden"))
  )
</script>
