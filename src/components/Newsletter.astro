---
---

<section class="bg-primary py-16 text-primary-foreground">
  <div
    class="mx-auto flex max-w-7xl flex-col items-start justify-between gap-8 px-5 lg:flex-row lg:items-center lg:px-8"
  >
    <div class="max-w-xl">
      <span class="eyebrow text-white/70">Newsletter GPTUR</span>
      <h2 class="mt-2 font-display text-3xl text-white sm:text-4xl">
        Receba as nossas ofertas e sugestões de viagem.
      </h2>
    </div>

    <form class="flex w-full max-w-md flex-col gap-3 sm:flex-row" data-newsletter>
      <input
        type="email"
        required
        placeholder="O seu email"
        aria-label="O seu email"
        class="h-12 flex-1 rounded-md border border-white/30 bg-white/10 px-4 text-sm text-white placeholder:text-white/60 focus:outline-none focus:ring-2 focus:ring-white"
      />
      <button
        type="submit"
        class="h-12 rounded-md bg-white px-6 text-sm font-semibold text-primary transition-colors hover:bg-cream"
      >
        Subscrever
      </button>
    </form>
  </div>
</section>

<script>
  document.querySelector<HTMLFormElement>("[data-newsletter]")?.addEventListener("submit", (e) => {
    e.preventDefault()
    const form = e.currentTarget as HTMLFormElement
    form.innerHTML =
      '<p class="text-white text-sm py-3">Obrigado pela sua subscrição! 🎉</p>'
  })
</script>
