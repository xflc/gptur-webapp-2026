---
import { trips } from "../data/trips"
import TripCard from "./TripCard.astro"

const featured = trips.filter((t) => t.featured)
---

<section id="catalogo" class="bg-cream py-20">
  <div class="mx-auto max-w-7xl px-5 lg:px-8">
    <div class="mb-10 flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-end">
      <div>
        <span class="eyebrow text-accent">Próximas partidas</span>
        <h2 class="mt-2 font-display text-4xl text-ink">Viagens em destaque</h2>
      </div>
      <a
        href="#catalogo"
        class="eyebrow border-b border-primary pb-1 text-[0.7rem] text-primary transition-colors hover:border-wine-800 hover:text-wine-800"
        >Ver catálogo completo →</a
      >
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {featured.map((trip) => <TripCard trip={trip} />)}
    </div>
  </div>
</section>
