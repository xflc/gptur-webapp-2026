---
import TripFinder from "./TripFinder.tsx"
import { regions, months } from "../data/trips"
---

<section class="bg-white py-20">
  <div class="mx-auto grid max-w-7xl gap-12 px-5 lg:grid-cols-[1.4fr_1fr] lg:px-8">
    <div>
      <span class="eyebrow text-accent">Agência de viagens · 50 anos</span>
      <h2 class="mt-3 max-w-2xl font-display text-3xl leading-tight text-ink sm:text-4xl">
        Viagens culturais em grupo e de autor, com guia em português durante
        todo o circuito.
      </h2>
      <div class="mt-6 space-y-4 text-[0.95rem] leading-relaxed text-muted-foreground">
        <p>
          A <strong class="text-foreground">gptur</strong> é um operador turístico
          especializado em viagens culturais em grupo. Com décadas de experiência,
          organizamos anualmente cerca de <strong class="text-foreground">1.000 circuitos</strong>,
          levando mais de 30.000 viajantes aos quatro cantos do mundo.
        </p>
        <p>
          A nossa programação, desenvolvida em exclusivo, contempla desde os
          destinos tradicionais aos mais invulgares — sempre com o
          acompanhamento de um guia da agência, em português, 24 horas por dia.
        </p>
      </div>

      <dl class="mt-8 grid grid-cols-3 gap-6 border-t border-border pt-8">
        <div>
          <dt class="font-display text-3xl font-semibold text-primary">1.000+</dt>
          <dd class="eyebrow mt-1 text-[0.6rem] text-muted-foreground">Circuitos por ano</dd>
        </div>
        <div>
          <dt class="font-display text-3xl font-semibold text-primary">30.000+</dt>
          <dd class="eyebrow mt-1 text-[0.6rem] text-muted-foreground">Viajantes</dd>
        </div>
        <div>
          <dt class="font-display text-3xl font-semibold text-primary">98,8%</dt>
          <dd class="eyebrow mt-1 text-[0.6rem] text-muted-foreground">Recomendam-nos</dd>
        </div>
      </dl>
    </div>

    <div class="lg:pt-2">
      <TripFinder client:load regions={regions} months={months} />
    </div>
  </div>
</section>
