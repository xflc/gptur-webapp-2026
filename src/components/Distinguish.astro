---
import { Compass, Users, BadgeCheck, BookOpen } from "lucide-react"

const features = [
  {
    icon: Compass,
    title: "Destinos invulgares",
    body: "Além dos clássicos, damos a conhecer destinos afastados das rotas convencionais, em muitos dos quais fomos pioneiros com grupos.",
  },
  {
    icon: BookOpen,
    title: "Viagens com Autores",
    body: "Experiências únicas partilhadas por um Autor, que lhes imprime uma identidade e sensibilidade próprias.",
  },
  {
    icon: Users,
    title: "Acompanhamento em português",
    body: "Um guia ou representante da agência acompanha todo o circuito, uma garantia da nossa presença e disponibilidade 24h.",
  },
  {
    icon: BadgeCheck,
    title: "Regime Tudo Incluído",
    body: "A maioria das viagens inclui pensão completa e entradas em museus e monumentos. Sem surpresas com despesas extra.",
  },
]
---

<section id="sustentabilidade" class="bg-ink py-20 text-white">
  <div class="mx-auto max-w-7xl px-5 lg:px-8">
    <div class="max-w-2xl">
      <span class="eyebrow text-olive-300">O que nos distingue</span>
      <h2 class="mt-2 font-display text-4xl text-white">
        Mais do que visitar um destino, vivê-lo.
      </h2>
    </div>

    <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {
        features.map((f) => (
          <div class="border-t border-white/15 pt-6">
            <f.icon className="text-olive-300" size={30} strokeWidth={1.5} />
            <h3 class="mt-4 font-display text-2xl text-white">{f.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-white/70">{f.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
