---
import { MapPin, Phone, Smartphone, Mail, Clock } from "lucide-react"

const info = [
  { label: "A nossa identidade", href: "/identidade" },
  { label: "Circuitos à medida", href: "/circuitos-a-medida" },
  { label: "Grupos", href: "/grupos" },
  { label: "Luas de mel", href: "/luas-de-mel" },
  { label: "Catálogo de viagens", href: "/catalogo" },
  { label: "Arquivo", href: "/arquivo" },
  { label: "Contactos", href: "/contactos" },
]
---

<footer id="contactos" class="bg-ink text-white/80">
  <div class="mx-auto max-w-7xl px-5 py-16 lg:px-8">
    <div class="grid gap-10 lg:grid-cols-3">
      <div>
        <img
          src="/gptur-logo-white.png"
          alt="GPTur"
          class="h-11 w-auto"
          width="4077"
          height="2224"
        />
        <p class="mt-5 text-sm leading-relaxed text-white/60">
          Desde 1979, o elo entre si e a sua próxima viagem. Organização de
          viagens à medida, com um rosto humano e assistência em todo o percurso.
        </p>
      </div>

      <div>
        <h3 class="eyebrow text-[0.65rem] text-white">Contactos</h3>
        <div class="mt-4 space-y-3 text-sm text-white/60">
          <p class="flex items-start gap-2">
            <Phone size={15} className="mt-0.5 shrink-0 text-gold-300" />
            <span>+351 217 530 021</span>
          </p>
          <p class="flex items-start gap-2">
            <Smartphone size={15} className="mt-0.5 shrink-0 text-gold-300" />
            <span>+351 913 813 584</span>
          </p>
          <p class="flex items-start gap-2">
            <Smartphone size={15} className="mt-0.5 shrink-0 text-gold-300" />
            <span>+351 912 283 835</span>
          </p>
          <p class="flex items-start gap-2">
            <Mail size={15} className="mt-0.5 shrink-0 text-gold-300" />
            <span>altalisboa@gptur.pt<br />lisboa@gptur.pt</span>
          </p>
          <p class="flex items-start gap-2">
            <Clock size={15} className="mt-0.5 shrink-0 text-gold-300" />
            <span>Balcão: 10h – 13h · 14h30 – 19h</span>
          </p>
          <p class="flex items-start gap-2">
            <MapPin size={15} className="mt-0.5 shrink-0 text-gold-300" />
            <span>R. Helena Vaz da Silva, 11<br />1750-405 Lisboa · Portugal</span>
          </p>
        </div>
      </div>

      <div>
        <h3 class="eyebrow text-[0.65rem] text-white">Informação</h3>
        <ul class="mt-4 space-y-2 text-sm">
          {
            info.map((l) => (
              <li>
                <a href={l.href} class="text-white/60 transition-colors hover:text-white">{l.label}</a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div
      class="mt-12 flex flex-col items-center justify-between gap-3 border-t border-white/15 pt-6 text-xs text-white/50 sm:flex-row"
    >
      <p>© {new Date().getFullYear()} GPTUR · RNAVT nº 1817. Todos os direitos reservados.</p>
      <p>Fora das horas de serviço, contacte-nos pelos restantes meios.</p>
    </div>
  </div>
</footer>
