---
// Ficha Google da GPTur (avaliações). Link de partilha oficial do negócio.
const googleReviews = "https://share.google/vj1Okm4BfydskFlxd"

const quotes = [
  {
    text: "Uma excelente agência, com ótimos programas e viagens muito bem organizadas. Recomendo a quem queira viajar.",
    author: "Maria L.",
  },
  {
    text: "Organização, simpatia, cuidado com o cliente, cumprimento de horários e programas. A minha agência de eleição.",
    author: "João P.",
  },
  {
    text: "Recomendo tudo. Desde a organização, à competência e delicadeza dos guias.",
    author: "Ana R.",
  },
]
---

<section class="bg-sand py-20">
  <div class="mx-auto max-w-7xl px-5 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-3">
      {
        quotes.map((q) => (
          <figure class="flex flex-col rounded-xl bg-white p-7 shadow-sm">
            <div class="font-display text-5xl leading-none text-accent">“</div>
            <blockquote class="mt-2 flex-1 text-[0.95rem] leading-relaxed text-foreground">
              {q.text}
            </blockquote>
            <figcaption class="eyebrow mt-5 text-[0.65rem] text-muted-foreground">
              {q.author}
            </figcaption>
          </figure>
        ))
      }
    </div>

    <p class="mx-auto mt-12 max-w-2xl text-center font-display text-2xl leading-snug text-ink">
      Há mais de quatro décadas que a nossa melhor publicidade é
      <span class="text-primary">a recomendação de quem viaja connosco</span>
      e nos apresenta a quem gosta.
    </p>
    <div class="mt-6 text-center">
      <a
        href={googleReviews}
        target="_blank"
        rel="noopener"
        class="eyebrow inline-block border-b border-primary pb-1 text-[0.7rem] text-primary transition-colors hover:border-teal-800 hover:text-teal-800"
        >Deixe a sua avaliação no Google →</a
      >
    </div>
  </div>
</section>
